rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Vitanalyze Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model where private data is isolated under 
     * user-specific paths (/users/{userId}). Authorization is primarily path-based, reinforced 
     * by denormalized ownership fields within documents to ensure relational integrity and 
     * performant queries.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Root profile for each user.
     * - /users/{userId}/...: Subcollections for user-specific data (Biometrics, Plans, Logs).
     * - /recipes, /exerciseSteps, /exerciseRoutines: Global, read-only libraries for all users.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Every user-owned document stores its own 'userId'. Rules 
     *    validate that this field matches the path parameter, preventing cross-user data leakage 
     *    without requiring expensive parent document lookups.
     * 2. Self-Creation: Users are permitted to create their own root profile document if the 
     *    document ID matches their authenticated UID.
     * 3. Read-Only Libraries: Shared resources like recipes are accessible to any signed-in 
     *    user but cannot be modified by clients.
     * 4. State Verification: All update and delete operations explicitly verify the document 
     *    exists before proceeding to prevent errors or unauthorized manipulation of non-existent data.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with a check that the document exists for destructive operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Allows self-registration and private access.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document '/users/abc' where data.id == 'abc'.
     * @deny (create) User 'abc' attempts to create document '/users/xyz'.
     * @principle Path-based ownership with self-creation rights.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Historical biometric data for a user.
       * @path /users/{userId}/biometricRecords/{recordId}
       * @allow (create) User 'abc' logs weight in their own subcollection.
       * @deny (list) User 'abc' tries to list records for user 'xyz'.
       * @principle Relational integrity enforced via denormalized userId.
       */
      match /biometricRecords/{recordId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User-specific meal plans generated by the AI coach.
       * @path /users/{userId}/mealPlans/{mealPlanId}
       * @allow (get) User 'abc' views their weekly meal plan.
       * @deny (update) User 'abc' tries to change the userId of a meal plan.
       * @principle Ownership isolation for personalized content.
       */
      match /mealPlans/{mealPlanId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Individual recipe entries within a specific meal plan.
         * @path /users/{userId}/mealPlans/{mealPlanId}/mealPlanEntries/{entryId}
         * @allow (create) User 'abc' adds a breakfast entry to their plan.
         * @principle Grandparent-based ownership verification.
         */
        match /mealPlanEntries/{entryId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.mealPlanId == mealPlanId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description User-specific exercise plans.
       * @path /users/{userId}/exercisePlans/{exercisePlanId}
       * @allow (list) User 'abc' fetches their current exercise schedule.
       * @principle Path-based authorization for nested resources.
       */
      match /exercisePlans/{exercisePlanId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Individual routine entries within an exercise plan.
         * @path /users/{userId}/exercisePlans/{exercisePlanId}/exercisePlanEntries/{entryId}
         * @allow (create) User 'abc' schedules a routine for Monday.
         * @principle Relational consistency between document fields and path segments.
         */
        match /exercisePlanEntries/{entryId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.exercisePlanId == exercisePlanId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Daily food intake logs.
       * @path /users/{userId}/foodLogs/{logId}
       * @allow (create) User 'abc' logs a meal with userId 'abc'.
       * @principle Private logging restricted to the authenticated user.
       */
      match /foodLogs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Daily physical activity logs.
       * @path /users/{userId}/activityLogs/{logId}
       * @allow (update) User 'abc' edits the duration of a logged activity.
       * @principle Document-level ownership for user activity data.
       */
      match /activityLogs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description AI-generated feedback and insights for the user.
       * @path /users/{userId}/coachingInsights/{insightId}
       * @allow (get) User 'abc' reads a nutrition tip generated for them.
       * @principle Restricted access to personalized AI insights.
       */
      match /coachingInsights/{insightId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global library of healthy recipes. Read-only for users.
     * @path /recipes/{recipeId}
     * @allow (get, list) Any signed-in user browses the recipe library.
     * @deny (create) Any user attempts to add a new recipe to the global library.
     * @principle Public read with restricted writes for shared resources.
     */
    match /recipes/{recipeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only library. Admin access not defined in IR.
    }

    /**
     * @description Global library of individual exercise steps. Read-only for users.
     * @path /exerciseSteps/{stepId}
     * @allow (list) User fetches a list of available exercise movements.
     * @principle Shared resource library protection.
     */
    match /exerciseSteps/{stepId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only library.
    }

    /**
     * @description Global library of exercise routines. Read-only for users.
     * @path /exerciseRoutines/{routineId}
     * @allow (get) User views details of a 'Full Body Strength' routine.
     * @principle Shared resource library protection.
     */
    match /exerciseRoutines/{routineId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Read-only library.
    }

  }
}